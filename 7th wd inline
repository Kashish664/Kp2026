<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Tribute Profile Page</title>
</head>
<body style="font-family: sans-serif; margin: 0; padding: 0; background-color: #f4f4f4;">

    <!-- Navigation Bar -->
    <nav style="background-color: #333; color: white; padding: 10px 0; text-align: center; border-bottom: 2px solid #4CAF50;">
        <a href="#home" style="color: white; text-decoration: none; padding: 10px 20px; margin: 0 10px; border: 1px solid transparent; transition: background-color 0.3s;" onmouseover="this.style.backgroundColor='#555'" onmouseout="this.style.backgroundColor='transparent'">Home</a>
        <a href="#about" style="color: white; text-decoration: none; padding: 10px 20px; margin: 0 10px; border: 1px solid transparent; transition: background-color 0.3s;" onmouseover="this.style.backgroundColor='#555'" onmouseout="this.style.backgroundColor='transparent'">About</a>
        <a href="#contact" style="color: white; text-decoration: none; padding: 10px 20px; margin: 0 10px; border: 1px solid transparent; transition: background-color 0.3s;" onmouseover="this.style.backgroundColor='#555'" onmouseout="this.style.backgroundColor='transparent'">Contact</a>
    </nav>

    <!-- Main Content Container -->
    <div style="width: 80%; margin: 20px auto; padding: 20px; background-color: white; box-shadow: 0 0 10px rgba(0,0,0,0.1); border: 1px solid #ddd; border-radius: 8px;">
        
        <!-- Header Section -->
        <header style="text-align: center; border-bottom: 2px solid #f4f4f4; padding-bottom: 20px;">
            <h1 style="color: #333; font-size: 2.5em;">John Doe</h1>
            <p style="color: #666; font-style: italic;">Web Developer & Designer</p>
        </header>

        <!-- Profile Image Section -->
        <section style="text-align: center; margin: 20px 0;">
            <img src="https://via.placeholder.com" alt="John Doe's profile picture" style="width: 150px; height: 150px; border-radius: 50%; border: 3px solid #4CAF50; object-fit: cover;">
        </section>

        <!-- About Section -->
        <section id="about" style="margin-bottom: 20px;">
            <h2 style="color: #4CAF50; border-left: 4px solid #333; padding-left: 10px;">About Me</h2>
            <p style="line-height: 1.6; color: #444;">
                Lorem ipsum dolor sit amet, consectetur adipiscing elit. Sed do eiusmod tempor incididunt ut labore et dolore magna aliqua. Ut enim ad minim veniam, quis nostrud exercitation ullamco laboris nisi ut aliquip ex ea commodo consequat.
            </p>
            <ul style="list-style-type: none; padding: 0;">
                <li style="background-color: #e9e9e9; margin: 5px 0; padding: 8px; border-radius: 4px; border: 1px solid #ddd;"><strong>Location:</strong> San Francisco, CA</li>
                <li style="background-color: #e9e9e9; margin: 5px 0; padding: 8px; border-radius: 4px; border: 1px solid #ddd;"><strong>Email:</strong> john@example.com</li>
            </ul>
        </section>

        <!-- Footer -->
        <footer style="text-align: center; margin-top: 40px; padding-top: 20px; border-top: 1px solid #ddd;">
            <p style="font-size: 0.9em; color: #888;">&copy; 2026 John Doe. All rights reserved.</p>
        </footer>

    </div>

</body>
</html>
